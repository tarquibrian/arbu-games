# Para Supabase local (apps/mobile/): npx supabase status, desde apps/mobile/
# Para producción: usar la URL y claves reales de tu proyecto Supabase.
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-or-prod-service-role-key
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_KEY=your-local-or-prod-publishable-key
